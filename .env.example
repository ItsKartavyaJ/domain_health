# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values before deploying
#   cp .env.example .env && nano .env
# ─────────────────────────────────────────────────────────────────────────────

# ── InfluxDB (shared by all three components) ────────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-admin-token
INFLUXDB_ORG=pintel
INFLUXDB_BUCKET=deliverability

# ── dmarc-dashboard server (uses different env var names for InfluxDB) ───────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influxdb-admin-token
INFLUX_ORG=pintel
INFLUX_BUCKET=dmarc

# ── Smartlead ────────────────────────────────────────────────────────────────
SMARTLEAD_API_KEY=your-smartlead-api-key

# ── DMARC mailbox (Gmail IMAP for parsedmarc) ────────────────────────────────
PARSEDMARC_IMAP_HOST=imap.gmail.com
PARSEDMARC_IMAP_PORT=993
PARSEDMARC_IMAP_USER=dmarc@yourdomain.com
PARSEDMARC_IMAP_PASSWORD=your-gmail-app-password
# Run parsedmarc once per interval instead of keeping an IMAP watch open.
PARSEDMARC_RUN_INTERVAL_SECONDS=3600

# ── dmarc-dashboard auth (Firebase) ─────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
ALLOWED_DOMAIN=yourdomain.com

# ── Alerting ─────────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id

# ── Optional: Google Postmaster Tools ───────────────────────────────────────
# POSTMASTER_CREDENTIALS_PATH=/opt/domain_health/postmaster-credentials.json

# ── Optional: tuning ─────────────────────────────────────────────────────────
# DIGEST_HOUR_UTC=8
# WARMUP_BATCH_DELAY_SECS=0.3
# CAMPAIGN_BOUNCE_THRESHOLD=3.0
# ALERT_THRESHOLD_SPAM_PCT=30.0
# LOG_FILE=/var/log/deliverability_monitor.log
# API_PORT=8787
