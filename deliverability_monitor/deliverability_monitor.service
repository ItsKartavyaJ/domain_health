[Unit]
Description=Pintel Deliverability Monitor
After=network-online.target influxdb.service
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
WorkingDirectory=/opt/domain_health/deliverability_monitor
Environment="PYTHONPATH=/opt/domain_health/deliverability_monitor"
ExecStart=/opt/domain_health/deliverability_monitor/.venv/bin/python /opt/domain_health/deliverability_monitor/scheduler.py
Restart=on-failure
RestartSec=30
StandardOutput=journal
StandardError=journal
SyslogIdentifier=deliverability-monitor

[Install]
WantedBy=multi-user.target

